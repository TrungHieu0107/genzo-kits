 ( SELECT      DENPYO_NB,      TORIHIKISAKI_CD,      BUNRUI1_CD,      TENPO_CD,      HACHU_DT,      NOHIN_DT,      KENSYU_DT,      ZAIKO_CENTER_CD,      KEIYU_CENTER_CD,      TOKUBAI_KB,      BUTURYU_KB,      TEIKAN_KB,       GENKA_ZEI_KB,      GENKA_ZEIRITSU_KB,      GENKA_ZEI_RT,      BAIKA_ZEI_KB,      BAIKA_ZEIRITSU_KB,      BAIKA_ZEI_RT,      BIN_KB,      DENPYOGYO_NB,      SYOHIN_CD,      HACHU_SYOHIN_CD,      SYOHIN_NA,      HI_KIKAKU_NA,      HI_KIKAKU_2_NA,      SYOHIN_KA,       HI_KIKAKU_KA,      HI_KIKAKU_2_KA,      BUNRUI2_CD,      BUNRUI3_CD,      BUNRUI4_CD,      BUNRUI5_CD,      HACHU_TANI_KA,      HACHU_TANI_QT,      HACHU_QT,      HACHU_SURYO_QT,      SYUKA_WEIGHT_QT,      GENTANKA_VL,      BAITANKA_VL,      GENKA_VL,      BAIKA_VL,      TEI_NOHIN_QT,      TEI_NOHIN_SURYO_QT,      TEI_GENTANKA_VL,      TEI_BAITANKA_VL,      TEI_GENKA_VL,      TEI_BAIKA_VL,      M_GENTANKA_VL,      M_BAITANKA_VL,      HAISHIN_HOHO_KB      ,HASU_SYORI_KB      ,GENKA_HASU_SYORI_KB      ,BAIKA_HASU_SYORI_KB  FROM         (        SELECT           IDK2.DENPYO_NB,          MIN(IDK2.TORIHIKISAKI_CD) TORIHIKISAKI_CD,          MIN(IDK2.BUNRUI1_CD) BUNRUI1_CD,          MIN(IDK2.TENPO_CD) TENPO_CD,          MIN(IDK2.HACHU_DT) HACHU_DT,          MIN(IDK2.NOHIN_DT) NOHIN_DT,          MIN(IDK2.KENSYU_DT) KENSYU_DT,          MIN(IDK2.ZAIKO_CENTER_CD) ZAIKO_CENTER_CD,          MIN(IDK2.KEIYU_CENTER_CD) KEIYU_CENTER_CD,          MIN(IDK2.TOKUBAI_KB) TOKUBAI_KB,          MIN(IDK2.BUTURYU_KB) BUTURYU_KB,          MIN(IDK2.TEIKAN_KB) TEIKAN_KB,          MIN(IDK2.GENKA_ZEI_KB) GENKA_ZEI_KB,          MIN(IDK2.GENKA_ZEIRITSU_KB) GENKA_ZEIRITSU_KB,          MIN(IDK2.GENKA_ZEI_RT) GENKA_ZEI_RT,          MIN(IDK2.BAIKA_ZEI_KB) BAIKA_ZEI_KB,          MIN(IDK2.BAIKA_ZEIRITSU_KB) BAIKA_ZEIRITSU_KB,          MIN(IDK2.BAIKA_ZEI_RT) BAIKA_ZEI_RT,          MIN(IDK2.BIN_KB) BIN_KB,          IDK2.DENPYOGYO_NB,          MIN(IDK2.SYOHIN_CD) SYOHIN_CD,          MIN(IDK2.HACHU_SYOHIN_CD) HACHU_SYOHIN_CD,          MIN(IDK2.SYOHIN_NA) SYOHIN_NA,          MIN(IDK2.HI_KIKAKU_NA) HI_KIKAKU_NA,          MIN(IDK2.HI_KIKAKU_2_NA) HI_KIKAKU_2_NA,          MIN(IDK2.SYOHIN_KA) SYOHIN_KA,          MIN(IDK2.HI_KIKAKU_KA) HI_KIKAKU_KA,          MIN(IDK2.HI_KIKAKU_2_KA) HI_KIKAKU_2_KA,          MIN(IDK2.BUNRUI2_CD) BUNRUI2_CD,          MIN(IDK2.BUNRUI3_CD) BUNRUI3_CD,          MIN(IDK2.BUNRUI4_CD) BUNRUI4_CD,          MIN(IDK2.BUNRUI5_CD) BUNRUI5_CD,          MIN(IDK2.HACHU_TANI_KA) HACHU_TANI_KA,          MIN(IDK2.HACHU_TANI_QT) HACHU_TANI_QT,          SUM(IDK2.HACHU_QT) HACHU_QT,          SUM(IDK2.HACHU_SURYO_QT) HACHU_SURYO_QT,          SUM(IDK2.SYUKA_WEIGHT_QT) SYUKA_WEIGHT_QT,          MIN(IDK2.GENTANKA_VL) GENTANKA_VL,          MIN(IDK2.BAITANKA_VL) BAITANKA_VL,          CONVERT(FLOAT,ROUND (SUM(IDK2.HACHU_SURYO_QT * GENTANKA_VL) , 0 , 1)) GENKA_VL,          CONVERT(FLOAT,ROUND (SUM(IDK2.HACHU_SURYO_QT * BAITANKA_VL) , 0 , 1)) BAIKA_VL,          SUM(IDK2.TEI_NOHIN_QT) TEI_NOHIN_QT,          SUM(IDK2.TEI_NOHIN_SURYO_QT) TEI_NOHIN_SURYO_QT,          MIN(IDK2.TEI_GENTANKA_VL) TEI_GENTANKA_VL,          MIN(IDK2.TEI_BAITANKA_VL) TEI_BAITANKA_VL,          CONVERT(FLOAT,ROUND (SUM(IDK2.TEI_NOHIN_SURYO_QT * TEI_GENTANKA_VL) , 0 , 1)) TEI_GENKA_VL,          CONVERT(FLOAT,ROUND (SUM(IDK2.TEI_NOHIN_SURYO_QT * TEI_BAITANKA_VL) , 0 , 1)) TEI_BAIKA_VL,          MIN(IDK2.M_GENTANKA_VL) M_GENTANKA_VL,          MIN(IDK2.M_BAITANKA_VL) M_BAITANKA_VL,          MIN(IDK2.HAISHIN_HOHO_KB) HAISHIN_HOHO_KB          ,MIN(RT2.HASU_SYORI_KB) HASU_SYORI_KB          ,MIN(RB1.GENKA_HASU_SYORI_KB) GENKA_HASU_SYORI_KB          ,MIN(RB1.BAIKA_HASU_SYORI_KB) BAIKA_HASU_SYORI_KB      FROM          WK_DT_KEIJO IDK2          LEFT JOIN R_TORIHIKISAKI RT2              ON RT2.COMP_CD = '0000'              AND RT2.TORIHIKISAKI_CD = IDK2.TORIHIKISAKI_CD              AND IDK2.NOHIN_DT BETWEEN RT2.TEKIYO_START_DT AND RT2.TEKIYO_END_DT              AND RT2.CHOAI_KB = '1'              AND RT2.TORIKESHI_FG = '0'              AND RT2.DELETE_FG = '0'              AND RT2.TORIHIKI_TEISHI_KB = '0'          LEFT JOIN R_BUNRUI1 RB1              ON RB1.BUNRUI1_CD = IDK2.BUNRUI1_CD              AND IDK2.NOHIN_DT BETWEEN RB1.YUKO_DT AND RB1.YUKO_END_DT              AND RB1.DELETE_FG = '0'      WHERE          IDK2.DENPYO_MAKE_KB = ?      GROUP BY          IDK2.DENPYO_NB,IDK2.DENPYOGYO_NB      ) SQ1  )  ORDER BY      DENPYO_NB,      DENPYOGYO_NB 
