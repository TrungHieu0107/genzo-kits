 ( SELECT      DENPYO_NB,      TORIHIKISAKI_CD,      BUNRUI1_CD,      TENPO_CD,      HACHU_DT,      NOHIN_DT,      KENSYU_DT,      ZAIKO_CENTER_CD,      KEIYU_CENTER_CD,      TOKUBAI_KB,      BUTURYU_KB,      TEIKAN_KB,       GENKA_ZEI_KB,      GENKA_ZEIRITSU_KB,      GENKA_ZEI_RT,      BAIKA_ZEI_KB,      BAIKA_ZEIRITSU_KB,      BAIKA_ZEI_RT,      BIN_KB,      DENPYOGYO_NB,      SYOHIN_CD,      HACHU_SYOHIN_CD,      SYOHIN_NA,      HI_KIKAKU_NA,      HI_KIKAKU_2_NA,      SYOHIN_KA,       HI_KIKAKU_KA,      HI_KIKAKU_2_KA,      BUNRUI2_CD,      BUNRUI3_CD,      BUNRUI4_CD,      BUNRUI5_CD,      HACHU_TANI_KA,      HACHU_TANI_QT,      HACHU_QT,      HACHU_SURYO_QT,      SYUKA_WEIGHT_QT,      GENTANKA_VL,      BAITANKA_VL,      GENKA_VL,      BAIKA_VL,      TEI_NOHIN_QT,      TEI_NOHIN_SURYO_QT,      TEI_GENTANKA_VL,      TEI_BAITANKA_VL,      TEI_GENKA_VL,      TEI_BAIKA_VL,      M_GENTANKA_VL,      M_BAITANKA_VL,      HAISHIN_HOHO_KB      ,HASU_SYORI_KB      ,GENKA_HASU_SYORI_KB      ,BAIKA_HASU_SYORI_KB  FROM         (        SELECT           IDK2.DENPYO_NB,          MIN(IDK2.TORIHIKISAKI_CD) TORIHIKISAKI_CD,          MIN(IDK2.BUNRUI1_CD) BUNRUI1_CD,          MIN(IDK2.TENPO_CD) TENPO_CD,          MIN(IDK2.HACHU_DT) HACHU_DT,          MIN(IDK2.NOHIN_DT) NOHIN_DT,          MIN(IDK2.KENSYU_DT) KENSYU_DT,          MIN(IDK2.ZAIKO_CENTER_CD) ZAIKO_CENTER_CD,          MIN(IDK2.KEIYU_CENTER_CD) KEIYU_CENTER_CD,          MIN(IDK2.TOKUBAI_KB) TOKUBAI_KB,          MIN(IDK2.BUTURYU_KB) BUTURYU_KB,          MIN(IDK2.TEIKAN_KB) TEIKAN_KB,          MIN(IDK2.GENKA_ZEI_KB) GENKA_ZEI_KB,          MIN(IDK2.GENKA_ZEIRITSU_KB) GENKA_ZEIRITSU_KB,          MIN(IDK2.GENKA_ZEI_RT) GENKA_ZEI_RT,          MIN(IDK2.BAIKA_ZEI_KB) BAIKA_ZEI_KB,          MIN(IDK2.BAIKA_ZEIRITSU_KB) BAIKA_ZEIRITSU_KB,          MIN(IDK2.BAIKA_ZEI_RT) BAIKA_ZEI_RT,          MIN(IDK2.BIN_KB) BIN_KB,          IDK2.DENPYOGYO_NB,          MIN(IDK2.SYOHIN_CD) SYOHIN_CD,          MIN(IDK2.HACHU_SYOHIN_CD) HACHU_SYOHIN_CD,